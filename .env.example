# =============================================================================
# Learning Loop AI — Environment Variable Template
# =============================================================================
# Copy this file to .env.local and fill in real values. Do NOT commit secrets.

# Clerk (Authentication) — https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Neon (PostgreSQL) — https://console.neon.tech
DATABASE_URL=
DIRECT_URL=

# Gemini API (AI Provider) — https://aistudio.google.com
GEMINI_API_KEY=

# AI service layer config (see lib/ai/config.ts)
AI_MODE=mock
AI_MODEL=gemini-2.5-flash-lite
